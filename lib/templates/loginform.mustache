<script>
(function () {
  const MODAL_ID = 'faqHelpModal';
  const SCROLL_SELECTOR = '.faq-scroll-content';

  function openFaqModal() {
    const el = document.getElementById(MODAL_ID);
    if (el) el.style.display = 'block';
  }

  function closeFaqModal() {
    const el = document.getElementById(MODAL_ID);
    if (el) el.style.display = 'none';
  }

  window.addEventListener('DOMContentLoaded', () => {
    openFaqModal();

    // Close buttons
    const faqModalClose = document.getElementById('faqModalClose');
    const faqModalFooterClose = document.getElementById('faqModalFooterClose');
    if (faqModalClose) faqModalClose.onclick = closeFaqModal;
    if (faqModalFooterClose) faqModalFooterClose.onclick = closeFaqModal;

    const container = document.querySelector(SCROLL_SELECTOR);
    if (!container) return;

    // First static answer (your default visible block)
    const firstAnswer = container.querySelector('.faq-answer.visible');

    // Ensure container has position context
    const cs = window.getComputedStyle(container);
    if (cs.position === 'static') container.style.position = 'relative';

    function offsetTopWithinContainer_usingOffset(el, container) {
      let offset = 0;
      let node = el;
      while (node && node !== container && node.offsetParent) {
        offset += node.offsetTop;
        node = node.offsetParent;
      }
      return (node === container) ? offset : null;
    }

    function offsetTopWithinContainer_usingRects(el, container) {
      const contRect = container.getBoundingClientRect();
      const elRect = el.getBoundingClientRect();
      return (elRect.top - contRect.top) + container.scrollTop;
    }

    function scrollToElementInside(container, element, padding = 12) {
      if (!container || !element) return;
      let top = offsetTopWithinContainer_usingOffset(element, container);
      if (top === null) {
        top = offsetTopWithinContainer_usingRects(element, container);
      }
      const target = Math.max(0, Math.floor(top - padding));
      container.scrollTo({ top: target, behavior: 'smooth' });
    }

    // Initialize: any .faq-answer.visible that already exists
    container.querySelectorAll('.faq-answer.visible').forEach(ans => {
      const q = ans.previousElementSibling;
      if (q && q.classList && q.classList.contains('faq-question')) {
        q.classList.add('expanded');
      }
    });

    // Handle clicks on questions
    container.addEventListener('click', (e) => {
      const btn = e.target.closest('.faq-question');
      if (!btn) return;

      e.preventDefault();

      const isExpanded = btn.classList.contains('expanded');

      // Collapse all dynamic answers
      container.querySelectorAll('.faq-question').forEach(q => q.classList.remove('expanded'));
      container.querySelectorAll('.faq-answer').forEach(a => {
        // Keep the first default block always visible
        if (a !== firstAnswer) a.classList.remove('visible');
      });

      // Always scroll such that the very top (firstAnswer) is in view
      if (firstAnswer) {
        scrollToElementInside(container, firstAnswer, 0);
      } else {
        container.scrollTo({ top: 0, behavior: 'smooth' });
      }

      if (!isExpanded) {
        btn.classList.add('expanded');
        const answer = btn.nextElementSibling;
        if (answer && answer.classList && answer.classList.contains('faq-answer')) {
          answer.classList.add('visible');

          // After layout update, if needed, ensure the newly opened answer is visible
          setTimeout(() => {
            scrollToElementInside(container, answer, 8);
          }, 160);
        }
      }
    });

    // Prevent image thumbs from toggling questions
    container.querySelectorAll('.faq-img-thumb').forEach(img => {
      img.addEventListener('click', (ev) => ev.stopPropagation());
    });

    // Image modal
    window.showFaqImageModal = function (src, alt) {
      const modal = document.getElementById('faqImgModal');
      const img = document.getElementById('faqImgModalImg');
      if (!modal || !img) return;
      img.src = src;
      img.alt = alt || 'FAQ screenshot';
      modal.style.display = 'flex';
      modal.onclick = function () {
        modal.style.display = 'none';
        img.src = '';
      };
    };
  });
})();
</script>


