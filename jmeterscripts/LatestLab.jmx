            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">// Generate a random 16-byte key and base64-encode it
def random = new byte[16]
new java.security.SecureRandom().nextBytes(random)
def secWebSocketKey = java.util.Base64.encoder.encodeToString(random)

// Store the key in a JMeter variable
vars.put(&quot;secWebSocketKey&quot;, secWebSocketKey)
</stringProp>
